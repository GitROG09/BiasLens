rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Global safety net
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() { return request.auth != null; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function isDataOwner() { return isSignedIn() && request.resource.data.userId == request.auth.uid; }
    function isResourceOwner() { return isSignedIn() && resource.data.userId == request.auth.uid; }

    // User Profiles
    match /users/{userId} {
      allow get: if isOwner(userId);
      allow create, update: if isOwner(userId) && 
        request.resource.data.keys().hasAll(['userId', 'email']) &&
        request.resource.data.userId == userId;
    }

    // Analyses
    match /analyses/{analysisId} {
      // List/Query must be restricted to owner
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow get: if isResourceOwner();
      allow create: if isDataOwner() &&
        request.resource.data.keys().hasAll(['userId', 'statement', 'timestamp', 'results']);
      allow delete: if isResourceOwner();
    }
  }
}
